@model IEnumerable<PrimeiroApp.Models.Usuario>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a class="btn btn-primary" asp-action="CadastrarUsuario" asp-controller="Usuario">Cadastrar</a>
</p>


<div class="table-responsive">
<table class="table table-bordered">
    <thead>
        <tr>
            <th scope="col">
                @Html.DisplayNameFor(model => model.UsuId)
            </th>
            <th scope="col">
                @Html.DisplayNameFor(model => model.nomeUsu)
            </th>
            <th scope="col">
                @Html.DisplayNameFor(model => model.Cargo)
            </th>
            <th scope="col">
                @Html.DisplayNameFor(model => model.DataNasc)
            </th>
            <th scope="col">Ação</th>
        </tr>
    </thead>
    <tbody>
@foreach (Usuario usuario in Model) {
        <tr>
            <td>
                @usuario.UsuId
            </td>
            <td>
                 @usuario.nomeUsu
            </td>
            <td>
                 @usuario.Cargo
            </td>
            <td>
                 @usuario.DataNasc.ToString("dd/MM/yyyy")
            </td>
            <td>
                <button type="button" class="btn btn-warning">

                @Html.ActionLink("Editar", "AtualizarUsuario", new {  id = usuario.UsuId  })
                        </button>
                        <button type="button" class="btn btn-secondary">
                @Html.ActionLink("Detalhes", "DetalhesUsuario", new { id = usuario.UsuId })
                        </button>
                        <button type="button" class="btn btn-danger">
                @Html.ActionLink("Excluir", "ExcluirUsuario", new {  id = usuario.UsuId },
                            new { onclick = "return confirm('Deseja realmente desativar?');" })
                        </button>
            </td>
        </tr>
}
    </tbody>
</table>
</div>
